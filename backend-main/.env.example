# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (REQUIRED)
JWT_SECRET=your-secret-key-here-change-this-in-production

# Database Configuration (SQLite - auto-created)
# Database file will be created at: backend/saira-acad.db
DATABASE_PATH=./saira-acad.db

# Default Admin Credentials
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=1234567@_a

# CORS Configuration
# Add your frontend URLs separated by commas, or use * to allow all origins
ALLOWED_ORIGINS=*

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# File Upload Configuration
MAX_FILE_SIZE=10485760
# 10MB in bytes

# Backup Configuration
BACKUP_RETENTION_DAYS=30

# Logging
LOG_LEVEL=info

# ==========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ==========================================
# 1. Copy this file to .env
# 2. Generate a strong JWT_SECRET: 
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 3. Set NODE_ENV=production
# 4. Update ALLOWED_ORIGINS with your production domain(s)
#    Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
#    Or keep * to allow all origins (useful for Render + Hostinger setup)
# 5. Change DEFAULT_ADMIN_PASSWORD to a strong password
# 6. Review and set appropriate RATE_LIMIT values
# 7. Set appropriate PORT for your hosting platform
# 8. NEVER commit .env file to version control
# ==========================================
